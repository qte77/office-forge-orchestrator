{
  "mcpServers": {
    "office-word": {
      "type": "stdio",
      "command": "uvx",
      "args": ["office-word-mcp-server"],
      "env": {}
    },
    "excel": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@negokaz/excel-mcp-server"],
      "env": {
        "EXCEL_MCP_PAGING_CELLS_LIMIT": "4000"
      }
    },
    "doccreator": {
      "type": "stdio",
      "command": "uvx",
      "args": ["mcp-server-doccreator"],
      "env": {}
    }
  }
}
